# ===== Database =====
POSTGRES_USER=legora
POSTGRES_PASSWORD=legora_dev_password
POSTGRES_DB=legora_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://legora:legora_dev_password@db:5432/legora_db

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== MinIO (S3-Compatible Storage) =====
MINIO_ROOT_USER=legora_minio
MINIO_ROOT_PASSWORD=legora_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=legora-documents
MINIO_ACCESS_KEY=legora_minio
MINIO_SECRET_KEY=legora_minio_password
MINIO_USE_SSL=false

# ===== Auth =====
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===== LLM Provider =====
# Options: openai, groq, local
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here
GROQ_API_KEY=gsk_your-groq-key-here

# ===== Embedding Model =====
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ===== Application =====
APP_ENV=development
APP_DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ===== MLflow =====
MLFLOW_TRACKING_URI=http://mlflow:5000
